# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored, so your secrets will never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Used ONLY on the server side (Next.js API route: src/app/api/gemini/route.ts).
# Do NOT rename this to NEXT_PUBLIC_GEMINI_API_KEY — that prefix would bundle
# the key into the client-side JavaScript and expose it to every browser visitor.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# These are safe to expose to the browser because they are scoped by Row-Level
# Security (RLS) policies in your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
